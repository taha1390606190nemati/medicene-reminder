# medicine.kv
# فایل طراحی کیوی

<LoginScreen>:
    BoxLayout:
        orientation: 'vertical'
        spacing: dp(10)
        padding: dp(30)
        
        Label:
            text: 'یادآور هوشمند دارو'
            font_size: dp(28)
            bold: True
            color: 0.1, 0.14, 0.49, 1  # #1a237e
        
        BoxLayout:
            orientation: 'vertical'
            spacing: dp(10)
            size_hint_y: None
            height: dp(350)
            
            Label:
                text: 'نام کاربری:'
                font_size: dp(14)
                size_hint_y: None
                height: dp(30)
            
            TextInput:
                id: username_input
                multiline: False
                font_size: dp(14)
                size_hint_y: None
                height: dp(40)
            
            Label:
                text: 'رمز عبور:'
                font_size: dp(14)
                size_hint_y: None
                height: dp(30)
            
            TextInput:
                id: password_input
                password: True
                multiline: False
                font_size: dp(14)
                size_hint_y: None
                height: dp(40)
            
            BoxLayout:
                orientation: 'vertical'
                spacing: dp(5)
                size_hint_y: None
                height: dp(100)
                
                Label:
                    id: captcha_label
                    text: ''
                    font_size: dp(16)
                    size_hint_y: None
                    height: dp(30)
                
                BoxLayout:
                    orientation: 'horizontal'
                    size_hint_y: None
                    height: dp(40)
                    
                    TextInput:
                        id: captcha_input
                        multiline: False
                        font_size: dp(14)
                        size_hint_x: 0.7
                    
                    Button:
                        text: '🔄'
                        size_hint_x: 0.3
                        background_color: 0.31, 0.76, 0.97, 1
                        on_press: root.generate_captcha()
        
        BoxLayout:
            orientation: 'horizontal'
            spacing: dp(10)
            size_hint_y: None
            height: dp(50)
            
            Button:
                text: 'ورود'
                background_color: 0, 0.81, 0.79, 1
                color: 0, 0, 0, 1
                font_size: dp(14)
                on_press: root.do_login()
            
            Button:
                text: 'ثبت پرستار'
                background_color: 0.04, 0.52, 0.89, 1
                color: 1, 1, 1, 1
                on_press: root.register('nurse')
            
            Button:
                text: 'ثبت بیمار'
                background_color: 0, 0.72, 0.58, 1
                color: 1, 1, 1, 1
                on_press: root.register('patient')
        
        Widget:


<DashboardScreen>:
    BoxLayout:
        orientation: 'horizontal'
        
        # سایدبار راست
        BoxLayout:
            orientation: 'vertical'
            size_hint_x: 0.2
            spacing: dp(5)
            padding: dp(10)
            background_color: 0.08, 0.08, 0.13, 1
            canvas.before:
                Color:
                    rgba: 0.08, 0.08, 0.13, 1
                Rectangle:
                    pos: self.pos
                    size: self.size
            
            Button:
                text: '💊 افزودن دارو'
                size_hint_y: None
                height: dp(44)
                background_color: 0.18, 0.18, 0.27, 1
                color: 1, 1, 1, 1
                font_size: dp(12)
                on_press: root.show_add_med()
            
            Button:
                text: '📋 لیست داروها'
                size_hint_y: None
                height: dp(44)
                background_color: 0.18, 0.18, 0.27, 1
                color: 1, 1, 1, 1
                font_size: dp(12)
                on_press: root.refresh_table()
            
            Button:
                text: '📊 آمار'
                size_hint_y: None
                height: dp(44)
                background_color: 0.18, 0.18, 0.27, 1
                color: 1, 1, 1, 1
                font_size: dp(12)
                on_press: root.show_stats()
            
            Button:
                text: '❓ راهنما'
                size_hint_y: None
                height: dp(44)
                background_color: 0.18, 0.18, 0.27, 1
                color: 1, 1, 1, 1
                font_size: dp(12)
                on_press: root.show_help()
            
            Button:
                text: 'ℹ️ درباره ما'
                size_hint_y: None
                height: dp(44)
                background_color: 0.18, 0.18, 0.27, 1
                color: 1, 1, 1, 1
                font_size: dp(12)
                on_press: root.show_about()
            
            Button:
                text: '🎨 تغییر تم'
                size_hint_y: None
                height: dp(44)
                background_color: 0.18, 0.18, 0.27, 1
                color: 1, 1, 1, 1
                font_size: dp(12)
                on_press: root.toggle_theme()
            
            Button:
                text: '🗑️ حذف انتخاب'
                size_hint_y: None
                height: dp(44)
                background_color: 0.18, 0.18, 0.27, 1
                color: 1, 1, 1, 1
                font_size: dp(12)
                on_press: root.delete_med()
            
            Button:
                text: '🚪 خروج'
                size_hint_y: None
                height: dp(44)
                background_color: 0.18, 0.18, 0.27, 1
                color: 1, 1, 1, 1
                font_size: dp(12)
                on_press: root.logout()
            
            Widget:
        
        # محتوای اصلی
        BoxLayout:
            orientation: 'vertical'
            padding: dp(20)
            spacing: dp(10)
            
            Label:
                text: f'{app.role.upper() if app.role else ""} PANEL - {app.fullname if app.fullname else ""}'
                font_size: dp(22)
                bold: True
                color: 0.1, 0.14, 0.49, 1
                size_hint_y: None
                height: dp(50)
            
            ScrollView:
                GridLayout:
                    id: table_layout
                    cols: 1
                    spacing: dp(2)
                    size_hint_y: None
                    height: self.minimum_height
                    row_default_height: dp(35)
                    
                    # هدر جدول
                    BoxLayout:
                        size_hint_y: None
                        height: dp(35)
                        spacing: dp(2)
                        
                        Label:
                            text: 'شناسه'
                            bold: True
                            color: 0.1, 0.14, 0.49, 1
                            font_size: dp(13)
                            size_hint_x: 0.2
                        
                        Label:
                            text: 'بیمار'
                            bold: True
                            color: 0.1, 0.14, 0.49, 1
                            font_size: dp(13)
                            size_hint_x: 0.2
                        
                        Label:
                            text: 'دارو'
                            bold: True
                            color: 0.1, 0.14, 0.49, 1
                            font_size: dp(13)
                            size_hint_x: 0.2
                        
                        Label:
                            text: 'ساعت'
                            bold: True
                            color: 0.1, 0.14, 0.49, 1
                            font_size: dp(13)
                            size_hint_x: 0.2
                        
                        Label:
                            text: 'روزها'
                            bold: True
                            color: 0.1, 0.14, 0.49, 1
                            font_size: dp(13)
                            size_hint_x: 0.2